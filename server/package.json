{
  "name": "server",
  "version": "1.0.0",
  "description": "Readify is a full-stack bookstore application built with Next.js, Express, PostgreSQL, and TypeScript. It features secure, role-based authentication for browsing, purchasing, and managing books.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "start": "bun ./dist/server.js",
    "lint": "bun eslint 'src/**/*.ts'",
    "format": "bun prettier --write .",
    "test": "bun test --passWithNoTests"
  },
  "keywords": [
    "bookstore",
    "api",
    "rbac",
    "express",
    "typescript",
    "zod"
  ],
  "author": "Md. Maruf Sarker",
  "license": "Apache License",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prettier": "^3.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}